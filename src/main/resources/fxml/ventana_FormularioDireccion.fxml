<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<ScrollPane fitToWidth="true" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml">
    <VBox spacing="10" prefWidth="500">
        <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
        </padding>

        <Text text="Dirección de envío" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

        <Label fx:id="etiquetaError" text="Por favor, completa todos los campos obligatorios antes de continuar."
               wrapText="true" visible="false" managed="false"
               style="-fx-text-fill: #b00000; -fx-background-color: #fdecec; -fx-padding: 8;"/>

        <Label text="Datos de la Dirección" style="-fx-font-weight: bold;"/>

        <Label text="NOMBRE COMPLETO" style="-fx-font-size: 11px; -fx-text-fill: #666666;"/>
        <TextField fx:id="campoNombreCompleto" promptText="Ej. Juan Pérez López"/>

        <Label text="CALLE" style="-fx-font-size: 11px; -fx-text-fill: #666666;"/>
        <TextField fx:id="campoCalle" promptText="Nombre de la calle"/>

        <Label text="NÚMERO" style="-fx-font-size: 11px; -fx-text-fill: #666666;"/>
        <TextField fx:id="campoNumero" promptText="123"/>

        <Label text="COLONIA" style="-fx-font-size: 11px; -fx-text-fill: #666666;"/>
        <TextField fx:id="campoColonia" promptText="Nombre de la colonia"/>

        <Label text="CIUDAD" style="-fx-font-size: 11px; -fx-text-fill: #666666;"/>
        <TextField fx:id="campoCiudad" promptText="Nombre de la ciudad"/>

        <Label text="ESTADO" style="-fx-font-size: 11px; -fx-text-fill: #666666;"/>
        <ComboBox fx:id="comboEstado" promptText="Selecciona un estado" maxWidth="Infinity"/>

        <Label text="CÓDIGO POSTAL" style="-fx-font-size: 11px; -fx-text-fill: #666666;"/>
        <TextField fx:id="campoCodigoPostal" promptText="00000"/>

        <HBox spacing="12">
            <Button fx:id="botonGuardar" text="Guardar" onAction="#handleGuardar"
                    style="-fx-background-color: black; -fx-text-fill: white;"/>
            <Button fx:id="botonCancelar" text="Cancelar" onAction="#handleCancelar"/>
        </HBox>

    </VBox>
</ScrollPane>
