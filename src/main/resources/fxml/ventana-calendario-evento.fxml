<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            prefWidth="1100.0"
            prefHeight="700.0">

    <top>
        <HBox alignment="CENTER" spacing="15" BorderPane.alignment="CENTER">
            <padding><Insets top="10" bottom="10"/></padding>
            <Button fx:id="btnPrev" text="◀"/>
            <Label fx:id="lblMes" text="JUNIO 2026" style="-fx-font-size:20px;-fx-font-weight:bold;"/>
            <Button fx:id="btnNext" text="▶"/>
        </HBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.62">

            <VBox spacing="5">

                <GridPane>
                    <Label text="S" GridPane.columnIndex="0"/>
                    <Label text="M" GridPane.columnIndex="1"/>
                    <Label text="T" GridPane.columnIndex="2"/>
                    <Label text="W" GridPane.columnIndex="3"/>
                    <Label text="T" GridPane.columnIndex="4"/>
                    <Label text="F" GridPane.columnIndex="5"/>
                    <Label text="S" GridPane.columnIndex="6"/>
                </GridPane>

                <GridPane fx:id="calendarGrid" gridLinesVisible="true">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="14.285"/>
                        <ColumnConstraints percentWidth="14.285"/>
                        <ColumnConstraints percentWidth="14.285"/>
                        <ColumnConstraints percentWidth="14.285"/>
                        <ColumnConstraints percentWidth="14.285"/>
                        <ColumnConstraints percentWidth="14.285"/>
                        <ColumnConstraints percentWidth="14.29"/>
                    </columnConstraints>

                    <rowConstraints>
                        <RowConstraints percentHeight="16.6"/>
                        <RowConstraints percentHeight="16.6"/>
                        <RowConstraints percentHeight="16.6"/>
                        <RowConstraints percentHeight="16.6"/>
                        <RowConstraints percentHeight="16.6"/>
                        <RowConstraints percentHeight="17.0"/>
                    </rowConstraints>

                    <!-- Las 42 celdas se generan desde el controlador -->
                </GridPane>

            </VBox>

            <VBox spacing="10">
                <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

                <HBox spacing="5">
                    <TextField fx:id="txtBuscar" promptText="Buscar evento..." HBox.hgrow="ALWAYS"/>
                    <Button text="Buscar"/>
                </HBox>

                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                    <VBox fx:id="panelEventos" spacing="10">

                        <TitledPane text="Evento asignado" expanded="true">
                            <VBox spacing="5">
                                <padding><Insets top="8" right="8" bottom="8" left="8"/></padding>
                                <Label text="31 Mayo"/>
                                <Label text="Feria del Mezcal"/>
                                <Label text="Iztapalapa"/>
                                <Label text="18:00 - 20:00"/>
                                <Button text="Editar"/>
                            </VBox>
                        </TitledPane>

                    </VBox>
                </ScrollPane>

            </VBox>

        </SplitPane>
    </center>

</BorderPane>
