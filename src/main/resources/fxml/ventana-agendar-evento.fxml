<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1">
            
    <center>

        <VBox spacing="20" alignment="TOP_CENTER">

            <padding>
                <Insets top="20" right="30" bottom="20" left="30"/>
            </padding>

            <Label text="Registro de Evento"
                   style="-fx-font-size:22px; -fx-font-weight:bold;" />

            <GridPane hgap="15" vgap="15">

                <!-- Nombre -->
                <Label text="Nombre del evento:"
                       GridPane.rowIndex="0"
                       GridPane.columnIndex="0"/>

                <TextField fx:id="txtNombreEvento"
                           promptText="Ingrese el nombre del evento"
                           GridPane.rowIndex="0"
                           GridPane.columnIndex="1"/>

                <!-- Tipo -->
                <Label text="Tipo de evento:"
                       GridPane.rowIndex="1"
                       GridPane.columnIndex="0"/>

                <ComboBox fx:id="cmbTipoEvento"
                          promptText="Seleccione"
                          prefWidth="250"
                          GridPane.rowIndex="1"
                          GridPane.columnIndex="1"/>

                <!-- Fecha -->
                <Label text="Fecha:"
                       GridPane.rowIndex="2"
                       GridPane.columnIndex="0"/>

                <DatePicker fx:id="dpFecha"
                            GridPane.rowIndex="2"
                            GridPane.columnIndex="1"/>

                <!-- Hora de inicio -->
                <Label text="Hora de inicio:"
                       GridPane.rowIndex="3"
                       GridPane.columnIndex="0"/>

                <TextField fx:id="txtHoraInicio"
                           promptText="Ej. 09:00"
                           GridPane.rowIndex="3"
                           GridPane.columnIndex="1"/>

                <!-- Hora de fin -->
                <Label text="Hora de fin:"
                       GridPane.rowIndex="4"
                       GridPane.columnIndex="0"/>

                <TextField fx:id="txtHoraFin"
                           promptText="Ej. 18:30"
                           GridPane.rowIndex="4"
                           GridPane.columnIndex="1"/>

                <!-- Acuerdo -->
                <Label text="Acuerdo económico:"
                       GridPane.rowIndex="5"
                       GridPane.columnIndex="0"/>

                <ComboBox fx:id="cmbAcuerdo"
                          promptText="Seleccione"
                          prefWidth="250"
                          GridPane.rowIndex="5"
                          GridPane.columnIndex="1"/>

                <!-- Notas -->
                <Label text="Notas adicionales:"
                       GridPane.rowIndex="6"
                       GridPane.columnIndex="0"/>

                <TextArea fx:id="txtNotas"
                          prefRowCount="4"
                          wrapText="true"
                          promptText="Escriba observaciones..."
                          GridPane.rowIndex="6"
                          GridPane.columnIndex="1"/>

            </GridPane>

            <!-- Empleados -->

            <Separator prefWidth="600"/>

            <Label text="Añadir empleado"
                   style="-fx-font-size:16px; -fx-font-weight:bold;"/>

            <HBox spacing="10" alignment="CENTER">

                <ComboBox fx:id="cmbEmpleado"
                          promptText="Seleccione un empleado"
                          prefWidth="300"/>

                <Button text="Agregar"
                        onAction="#agregarEmpleado"/>

            </HBox>

            <ListView fx:id="lvEmpleados"
                      prefHeight="150"
                      prefWidth="450"/>

            <HBox spacing="15" alignment="CENTER">

                <Button text="Cancelar"
                        onAction="#cancelarEvento"/>

                <Button text="Guardar Evento"
                        onAction="#guardarEvento"/>
                
                <Button text="Confirmar Registro"
                        onAction="#confirmarRegistro"/>

            </HBox>

        </VBox>

    </center>

</BorderPane>